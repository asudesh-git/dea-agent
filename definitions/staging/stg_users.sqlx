config {
  type: "view",
  tags: ["staging", "auto-cleaning"],
  description: "Staging table for user data with cleaning and standardization.",
  columns: {
    id: "User ID",
    full_name: "User's full name",
    email: "User's email address",
    age: "User's age",
    gender: "User's gender (M/F)",
    state: "State where the user resides",
    street_address: "User's street address",
    postal_code: "User's postal code",
    city: "City where the user resides",
    country: "Country where the user resides",
    traffic_source: "Source of user traffic",
    created_at: "Timestamp of user creation",
    user_geom: "Geography object representing user's location, created from a WKT string."
  }
}

SELECT
  id,
  CONCAT(first_name, ' ', last_name) AS full_name,
  LOWER(email) AS email,
  age,
  CASE
    WHEN gender = 'Male' THEN 'M'
    WHEN gender = 'Female' THEN 'F'
    ELSE NULL
  END AS gender,
  state,
  street_address,
  postal_code,
  city,
  country,
  traffic_source,
  created_at,
  SAFE.ST_GEOGFROMTEXT(user_geom) AS user_geom
FROM
  ${ref("raw_users")}
