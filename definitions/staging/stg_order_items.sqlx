
config { 
    type: "view",
    tags: ["staging", "auto-cleaning"],
    description: "Staging table for order items data with cleaning and standardization.",
    columns: {
        order_id: "Order ID",
        user_id: "User ID",
        product_id: "Product ID",
        inventory_item_id: "Inventory Item ID",
        status: "Status of the order item",
        created_at: "Timestamp of order item creation",
        shipped_at: "Timestamp of order item shipment",
        delivered_at: "Timestamp of order item delivery",
        returned_at: "Timestamp of order item return",
        item_revenue: "Revenue generated by the order item"
    }
}

SELECT
  order_id,
  user_id,
  product_id,
  inventory_item_id,
  LOWER(status) AS status,
  created_at,
  shipped_at,
  delivered_at,
  returned_at,
  sale_price AS item_revenue
FROM
  ${ref("raw_order_items")}