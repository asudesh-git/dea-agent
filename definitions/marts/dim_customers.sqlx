
config { 
    type: "table",
    tags: ["marts"],
    description: "Dimension table for customers."
}

SELECT
  id AS customer_id,
  full_name,
  email,
  age,
  gender,
  state,
  street_address,
  postal_code,
  city,
  country,
  latitude,
  longitude,
  traffic_source,
  created_at AS customer_created_at
FROM
  ${ref("stg_users")}